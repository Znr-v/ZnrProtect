generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Serveurs ───

model Guild {
  id                String   @id // Discord guild ID
  name              String
  ownerId           String
  riskScore         Int      @default(0)
  lockdownActive    Boolean  @default(false)
  lockdownAt        DateTime?
  joinedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  config            GuildConfig?
  members           Member[]
  securityEvents    SecurityEvent[]
  incidents         Incident[]
  rules             Rule[]
  auditSnapshots    AuditSnapshot[]
  permissionChanges PermissionChange[]
  detectedLinks     DetectedLink[]
  detectedSecrets   DetectedSecret[]
  configVersions    ConfigVersion[]
  canaryChannels    CanaryChannel[]
  webhookEntries    WebhookEntry[]
  inviteStats       InviteStats[]
  botActionLogs     BotActionLog[]
  guildRoles        GuildRole[]
}

model GuildConfig {
  id                   String  @id @default(cuid())
  guildId              String  @unique
  guild                Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // Anti-raid
  raidJoinThreshold    Int     @default(10)
  raidJoinWindow       Int     @default(60) // secondes
  raidAutoLockdown     Boolean @default(true)
  raidMinAccountAge    Int     @default(3) // jours
  raidSanction         ActionType @default(BAN)

  // Anti-spam (users)
  spamMaxMessages      Int     @default(5)
  spamMaxMessages10s   Int     @default(8)
  spamRepeatThreshold  Int     @default(3)
  spamMaxMentions      Int     @default(3)
  spamMaxMentions10s   Int     @default(5)
  spamMuteDuration     Int     @default(5) // minutes
  spamAutoDelete       Boolean @default(true)
  spamSanction         ActionType @default(TIMEOUT)

  // Anti-spam (bots) - more sensitive
  botSpamMaxMessages     Int     @default(3)
  botSpamMaxMessages5s   Int     @default(5)
  botSpamCrossChannel     Int     @default(2) // channels in 5s to trigger
  botSpamSanction         ActionType @default(KICK)

  // Anti-phishing
  phishingEnabled        Boolean @default(true)
  phishingCheckRedirects  Boolean @default(true)
  phishingSanction       ActionType @default(QUARANTINE)

  // Secrets
  secretScanEnabled    Boolean @default(true)
  secretSanction       ActionType @default(QUARANTINE)

  // Scan bots
  scanBots             Boolean @default(false)

  // Quarantine
  quarantineRoleId       String?
  quarantineEnabled      Boolean @default(true)
  quarantineMinScore     Int     @default(61)
  quarantineAutoOnJoin   Boolean @default(true)

  // Trust zones
  strictChannels       String[] @default([])
  relaxedChannels      String[] @default([])

  // Emergency
  emergencyEnabled     Boolean @default(true)

  // Timeout global par défaut
  defaultTimeoutMinutes Int    @default(5)

  updatedAt            DateTime @updatedAt
}

// ─── Logs d'actions du bot ───

model BotActionLog {
  id            String   @id @default(cuid())
  guildId       String
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  action        String
  targetId      String?
  targetName    String?
  moderatorId   String?
  moderatorName String?
  channelId     String?
  executedBy    String   @default("bot") // "bot" or "moderator"
  reason        String?
  details       Json?
  createdAt     DateTime @default(now())

  @@index([guildId, createdAt])
}

// ─── Membres ───

model Member {
  id            String    @id @default(cuid())
  discordId     String
  guildId       String
  guild         Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  username      String
  isBot         Boolean   @default(false)
  joinedAt      DateTime  @default(now())
  accountAge    DateTime
  riskScore     Int       @default(0)
  quarantined   Boolean   @default(false)
  trusted       Boolean   @default(false)
  messageCount  Int       @default(0)
  linkCount     Int       @default(0)
  warnCount     Int       @default(0)
  timedOutUntil DateTime?
  updatedAt     DateTime  @updatedAt

  riskScores    RiskScore[]

  @@unique([discordId, guildId])
  @@index([guildId, riskScore])
}

// ─── Events de sécurité ───

enum EventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EventType {
  RAID_DETECTED
  SPAM_DETECTED
  PHISHING_LINK
  SECRET_LEAKED
  PERMISSION_CHANGE
  SUSPICIOUS_JOIN
  MASS_BAN
  MASS_KICK
  CHANNEL_DELETE
  WEBHOOK_CREATED
  WEBHOOK_SPAM
  ROLE_ESCALATION
  MODERATOR_ANOMALY
  CANARY_TRIGGERED
  EMERGENCY_ACTIVATED
  QUARANTINE_APPLIED
  INVITE_SUSPICIOUS
}

model SecurityEvent {
  id          String        @id @default(cuid())
  guildId     String
  guild       Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  type        EventType
  severity    EventSeverity
  actorId     String?       // Discord user ID qui a causé l'event
  channelId   String?
  description String
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())

  incidentId  String?
  incident    Incident?     @relation(fields: [incidentId], references: [id])

  @@index([guildId, createdAt])
  @@index([type, severity])
}

// ─── Actions bot ───

enum ActionType {
  TIMEOUT
  KICK
  KICK_DELETE
  BAN
  QUARANTINE
}

// ─── Incidents ───

enum IncidentStatus {
  NEW
  IN_PROGRESS
  CONTAINED
  RESOLVED
  FALSE_POSITIVE
}

model Incident {
  id            String          @id @default(cuid())
  guildId       String
  guild         Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  title         String
  severity      EventSeverity
  status        IncidentStatus  @default(NEW)
  description   String?
  isBot         Boolean         @default(false)
  actionType    String?         // kick, kick_delete, timeout, etc.
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  resolvedAt    DateTime?
  resolvedBy    String?

  events        SecurityEvent[]
  actions       IncidentAction[]

  @@index([guildId, status])
}

model IncidentAction {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  action      String   // kick, ban, quarantine, mute, delete_message, lockdown, etc.
  targetId    String?  // Discord user ID
  executedBy  String   // bot or moderator ID
  reason      String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
}

// ─── Risk scores ───

model RiskScore {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  score     Int
  factors   Json     // { accountAge: 20, spamRate: 15, linkRatio: 10, ... }
  createdAt DateTime @default(now())

  @@index([memberId, createdAt])
}

// ─── Règles ───

model Rule {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name        String
  description String?
  condition   Json     // { type: "join_rate", threshold: 10, window: 60 }
  action      Json     // { type: "quarantine" } or { type: "lockdown" }
  enabled     Boolean  @default(true)
  shadowMode  Boolean  @default(false) // "Shadow Rules Test"
  matchCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches     RuleMatch[]

  @@index([guildId, enabled])
}

model RuleMatch {
  id        String   @id @default(cuid())
  ruleId    String
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  actorId   String?
  channelId String?
  metadata  Json     @default("{}")
  shadow    Boolean  @default(false) // matched but not executed
  createdAt DateTime @default(now())

  @@index([ruleId, createdAt])
}

// ─── Audit ───

model AuditSnapshot {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  snapshot  Json     // roles, channels, permissions at point in time
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

model PermissionChange {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roleId      String
  roleName    String
  changeType  String   // added, removed, modified
  permission  String
  changedBy   String?  // user ID who made the change
  flagged     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([guildId, createdAt])
}

// ─── Liens & secrets détectés ───

model DetectedLink {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  url         String
  domain      String
  actorId     String
  channelId   String
  reason      String   // phishing, redirect_chain, punycode, recent_domain, etc.
  confidence  Float    @default(0)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([domain])
}

model DetectedSecret {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  actorId     String
  channelId   String
  secretType  String   // discord_token, api_key, jwt, private_key, etc.
  secretHash  String   // SHA-256
  createdAt   DateTime @default(now())

  @@index([guildId, createdAt])
}

// ─── Config versioning ───

model ConfigVersion {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  config    Json
  changedBy String
  changelog String?
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

// ─── Canary channels ───

model CanaryChannel {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  type      String   @default("honeypot") // honeypot, semi_visible
  triggers  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([guildId, channelId])
}

// ─── Webhooks ───

model WebhookEntry {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  webhookId   String
  channelId   String
  createdBy   String?
  name        String
  flagged     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([guildId, webhookId])
}

// ─── Invite stats ───

model InviteStats {
  id              String   @id @default(cuid())
  guildId         String
  guild           Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  inviteCode      String
  inviterId       String?
  usesTotal       Int      @default(0)
  usesSuspicious  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([guildId, inviteCode])
}

// ─── Dashboard users ───

enum DashboardRole {
  OWNER
  ADMIN
  MODERATOR
  VIEWER
}

model DashboardUser {
  id          String       @id @default(cuid())
  discordId   String       @unique
  username    String
  avatar      String?
  role        DashboardRole @default(VIEWER)
  language    String        @default("fr")
  approved    Boolean      @default(false)
  approvedBy  String?
  createdAt   DateTime     @default(now())
  lastLoginAt DateTime?
  guildPermissions DashboardGuildPermission[]
}

model DashboardGuildPermission {
  id          String   @id @default(cuid())
  userId      String
  user        DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId     String
  role        DashboardRole @default(VIEWER)
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, guildId])
}

model DashboardAuditLog {
  id        String   @id @default(cuid())
  actorId   String
  guildId   String?
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model GuildRole {
  id            String   @id @default(cuid())
  guildId       String
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  discordRoleId String?
  name          String
  color         String   @default("#99AAb5")
  position      Int      @default(0)
  discordPermissions String[] @default([])
  panelPermissions   String[] @default([])
  hoist          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([guildId, discordRoleId])
  @@unique([guildId, name])
}

// ─── Quarantaine - stockage des rôles ───

model QuarantinedMember {
  id            String   @id @default(cuid())
  guildId       String
  discordId     String   // ID du membre mis en quarantaine
  username      String
  roles         String[] // IDs des rôles originaux (stockés quand quarantine appliquée)
  quarantinedAt DateTime @default(now())
  quarantinedBy String?  // ID du mod ou "AUTO"

  @@unique([guildId, discordId])
}
